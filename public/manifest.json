{
  "name": "FIFA Smart Stadium AI - Mission Control",
  "short_name": "Smart Stadium",
  "description": "AI Operating System for FIFA World Cup 2026 - Real-time crowd management, emergency response, and operational intelligence.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#0a0e27",
  "theme_color": "#22d3ee",
  "orientation": "portrait-primary",
  "start_display": "window",
  "icons": [
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-maskable-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/narrow.png",
      "sizes": "540x720",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "/screenshots/wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],
  "shortcuts": [
    {
      "name": "Live Presentation",
      "short_name": "Demo",
      "description": "Launch FIFA Smart Stadium AI presentation",
      "url": "/demo?launch=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-demo.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Operations Dashboard",
      "short_name": "Ops",
      "description": "Open operations command center",
      "url": "/ops?launch=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-ops.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Fan Experience",
      "short_name": "Fans",
      "description": "Access fan portal",
      "url": "/fan?launch=shortcut",
      "icons": [
        {
          "src": "/icons/shortcut-fan.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "categories": ["sports", "productivity"],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/png", "image/jpeg", "video/mp4"]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/open-incident",
      "accept": {
        "application/json": [".incident"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+fifa",
      "url": "/?incident=%s"
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-new", "auto"]
  }
}

