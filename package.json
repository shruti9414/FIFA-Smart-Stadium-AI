{
  "name": "fifa-smart-stadium-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "next build --webpack && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --tsconfig=tsconfig.json --outfile=server.compiled.js",
    "start": "cross-env NODE_ENV=production node server.compiled.js",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "db:init": "node --env-file=.env.local scripts/db-init.mjs",
    "db:seed": "node --env-file=.env.local scripts/db-seed.mjs",
    "generate-icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tailwindcss/postcss": "^4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "mysql2": "^3.22.6",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "three": "^0.185.1",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/mysql": "^2.15.27",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "typescript": "^5"
  }
}
